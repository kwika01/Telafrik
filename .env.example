# Supabase — get from https://supabase.com/dashboard/project/<project>/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# OpenAI — used for Ask TelAfrik AI chat (gpt-4o-mini)
# Get from https://platform.openai.com/api-keys
# NOTE: VITE_ prefix exposes this in the client bundle.
# For production at scale, proxy through a Vercel serverless function.
VITE_OPENAI_API_KEY=sk-proj-...
